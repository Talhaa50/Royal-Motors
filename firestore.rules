rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All app data lives at  users/{uid}/store/{key}
    // Written by firebase-sync.js as  { json: string, updatedAt: timestamp }
    match /users/{uid}/store/{key} {

      // The authenticated owner may read any of their own store documents.
      allow read: if request.auth != null
                  && request.auth.uid == uid;

      // Write is allowed only when all of the following hold:
      //  1. Caller is authenticated as the document owner.
      //  2. Key matches the app's storage-key convention (fo_ prefix).
      //  3. Document contains exactly the two expected fields — no extras.
      //  4. json is a non-empty string (serialised JSON).
      //  5. updatedAt is a server-generated timestamp (FieldValue.serverTimestamp()).
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && key.matches('fo_[a-z_0-9]+')
                   && request.resource.data.keys().hasOnly(['json', 'updatedAt'])
                   && request.resource.data.json is string
                   && request.resource.data.json.size() > 0
                   && request.resource.data.updatedAt is timestamp;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
